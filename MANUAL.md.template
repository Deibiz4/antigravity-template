## Guía Rápida

### Primer uso: Ejemplo básico

```javascript
// Importar
const { myFunction } = require('proyecto');

// Usar
const result = myFunction({
  name: 'Juan',
  email: 'juan@example.com'
});

console.log(result); // { success: true, id: 123 }
```

### Caso de uso: Procesar datos

```javascript
const app = require('proyecto');

async function procesarDatos() {
  try {
    const datos = await app.getData();
    const procesado = app.transform(datos);
    await app.save(procesado);
    console.log('✅ Datos procesados');
  } catch (error) {
    console.error('❌ Error:', error.message);
  }
}

procesarDatos();
```

