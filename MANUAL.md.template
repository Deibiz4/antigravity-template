## Ejemplos de Uso

### Ejemplo 1: Operación Básica

```javascript
const proyecto = require('proyecto');

// Inicializar
const app = proyecto.init({
  apiKey: process.env.API_KEY
});

// Usar
app.doSomething();
```

### Ejemplo 2: Manejo de Errores

```javascript
async function miOperacion() {
  try {
    const resultado = await proyecto.procesarDatos();
    return resultado;
  } catch (error) {
    console.error(`Error: ${error.message}`);
    // Intentar recuperación
    return await proyecto.procesarDatos.retry();
  }
}
```

### Ejemplo 3: Flujo Completo

```javascript
async function flujoCompleto() {
  // 1. Obtener datos
  const datos = await proyecto.getData();
  
  // 2. Transformar
  const transformado = datos.map(d => ({
    ...d,
    procesado: true,
    fecha: new Date()
  }));
  
  // 3. Guardar
  await proyecto.guardar(transformado);
  
  // 4. Reportar
  console.log(`✅ ${transformado.length} registros procesados`);
}

flujoCompleto();
```

